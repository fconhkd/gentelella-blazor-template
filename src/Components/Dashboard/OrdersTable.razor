<div class="card">
    <div class="card-header">
        <div>
            <div class="card-title">Recent Orders</div>
            <div class="card-subtitle">Latest 5 transactions</div>
        </div>
        <button type="button" class="btn btn-outline btn-sm">View All</button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Items)
                    {
                        <tr @key="order.Order">
                            <td class="cell-mono">@order.Order</td>
                            <td>
                                <div class="cell-customer">
                                    <span class="cell-avatar @order.AvatarColor">@order.CustomerInitials</span>
                                    <span class="cell-strong">@order.Customer</span>
                                </div>
                            </td>
                            <td>@order.Product</td>
                            <td class="cell-strong">@order.Amount</td>
                            <td><span class="status @order.StatusClass">@order.Status</span></td>
                            <td>@order.Date</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<OrderItem> Items { get; set; } = [];
}
