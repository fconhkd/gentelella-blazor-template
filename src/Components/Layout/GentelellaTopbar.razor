@inject NavigationManager Navigation

<header class="topbar">
    <div class="topbar-left">
        <button type="button" class="sidebar-toggle" data-sidebar-toggle aria-label="Toggle sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <nav class="breadcrumb" aria-label="Breadcrumb">
            <span>Home</span>
            <span class="sep">/</span>
            <span class="current">@CurrentPage</span>
        </nav>
    </div>

    <div class="search-box" role="search">
        <svg class="s-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="M20 20l-3.2-3.2" />
        </svg>
        <input type="search" placeholder="Search dashboards" aria-label="Search" />
        <kbd>Ctrl K</kbd>
    </div>

    <div class="topbar-right">
        <a class="tb-btn tb-docs" href="https://gentelella.colorlib.com/docs/" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 19.5V5a2 2 0 0 1 2-2h12v18H6a2 2 0 0 1-2-1.5Z" />
                <path d="M8 7h7M8 11h7M8 15h4" />
            </svg>
            Docs
        </a>

        <button type="button" class="tb-btn theme-toggle" data-theme-toggle aria-label="Toggle theme">
            <svg class="theme-icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 3v2M12 19v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M3 12h2M19 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
                <circle cx="12" cy="12" r="4" />
            </svg>
            <svg class="theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z" />
            </svg>
        </button>

        <button type="button" class="tb-btn tb-notifications" aria-label="Notifications">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 3a6 6 0 0 0-6 6c0 5-2 6.5-2 6.5h16S18 14 18 9a6 6 0 0 0-6-6Z" />
                <path d="M10 19a2 2 0 0 0 4 0" />
            </svg>
            <span class="dot"></span>
        </button>

        <button type="button" class="tb-btn tb-messages" aria-label="Messages">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="3" />
                <path d="m4 7 8 6 8-6" />
            </svg>
        </button>

        <UserAccountMenu Variant="topbar" />
    </div>
</header>

@code {
    private string CurrentPage
    {
        get
        {
            var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/');

            return path switch
            {
                "" => "Dashboard",
                "weather" => "Dynamic tables",
                "users" => "User management",
                "profile" => "Profile",
                "settings" => "Settings",
                "login" => "Login",
                _ => "Dashboard"
            };
        }
    }
}
