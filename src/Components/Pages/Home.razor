@page "/"

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <div class="page-pretitle">Overview</div>
            <h1 class="page-title">Dashboard</h1>
        </div>
        <div class="page-actions">
            <button type="button" class="btn btn-outline">New view</button>
            <button type="button" class="btn btn-primary">Create report</button>
        </div>
    </div>
</div>

<div class="row col-3">
    @foreach (var stat in Stats.Take(3))
    {
        <StatCard Item="stat" @key="stat.Label" />
    }
</div>

<div class="row col-3">
    @foreach (var stat in Stats.Skip(3))
    {
        <StatCard Item="stat" @key="stat.Label" />
    }
</div>

<div class="row col-8-4">
    <NetworkChartCard />
    <ActivityFeed Items="Activities" />
</div>

<div class="row col-8-4">
    <OrdersTable Items="Orders" />
    <div class="dashboard-stack">
        <StorageCard Segments="Storage" />
        <DeviceUsageCard Segments="Devices" />
    </div>
</div>

<div class="row col-3">
    <VisitorsCard Items="Visitors" />
    <TasksCard Items="Tasks" />
    <AppVersionsCard Items="Versions" />
</div>

