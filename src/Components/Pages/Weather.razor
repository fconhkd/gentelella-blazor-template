@page "/weather"
@attribute [StreamRendering]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Dynamic weather table</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <div class="page-pretitle">Tables</div>
            <h1 class="page-title">Server data - weather</h1>
        </div>
        <div class="page-actions">
            <button type="button" class="btn btn-outline" @onclick="RefreshForecastsAsync">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M20 11a8.1 8.1 0 0 0-15.5-2M4 5v4h4" />
                    <path d="M4 13a8.1 8.1 0 0 0 15.5 2M20 19v-4h-4" />
                </svg>
                Refresh
            </button>
            <a class="btn btn-outline" href="@CsvDataUri" download="weather-forecasts.csv">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M5 21h14" />
                </svg>
                Export CSV
            </a>
        </div>
    </div>
</div>

<div class="card weather-grid-card">
    <div class="card-header">
        <div>
            <div class="card-title">Weather forecasts</div>
            <div class="card-subtitle">Sortable columns, search across all fields, paginated 25/page.</div>
        </div>
    </div>

    @if (forecasts == null)
    {
        <div class="card-body">
            <div class="weather-grid-loading">
                <span class="weather-loading-icon" aria-hidden="true"></span>
                <span>Loading weather data...</span>
            </div>
        </div>
    }
    else
    {
        <div class="weather-grid-toolbar">
            <label class="weather-grid-length">
                <span>Show</span>
                <select class="form-control" aria-label="Entries per page" value="@pageSize" @onchange="OnPageSizeChanged">
                    <option>10</option>
                    <option>25</option>
                    <option>50</option>
                    <option>100</option>
                </select>
                <span>entries</span>
            </label>

            <div class="search-box weather-grid-search" role="search">
                <svg class="s-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" />
                    <path d="M20 20l-3.2-3.2" />
                </svg>
                <input type="search" placeholder="Search weather" aria-label="Search weather" value="@searchTerm" @oninput="OnSearchInput" />
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table weather-table">
                    <thead>
                        <tr>
                            <th>
                                <button type="button" class='weather-sort @SortClass("Date")' @onclick='() => SortBy("Date")'>
                                    Date
                                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                        <path d="M5 6l3-3 3 3M11 10l-3 3-3-3" />
                                    </svg>
                                </button>
                            </th>
                            <th>
                                <button type="button" class='weather-sort @SortClass("Location")' @onclick='() => SortBy("Location")'>
                                    Location
                                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                        <path d="M5 6l3-3 3 3M11 10l-3 3-3-3" />
                                    </svg>
                                </button>
                            </th>
                            <th>
                                <button type="button" class='weather-sort @SortClass("Summary")' @onclick='() => SortBy("Summary")'>
                                    Summary
                                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                        <path d="M5 6l3-3 3 3M11 10l-3 3-3-3" />
                                    </svg>
                                </button>
                            </th>
                            <th>
                                <button type="button" class='weather-sort @SortClass("TemperatureC")' @onclick='() => SortBy("TemperatureC")'>
                                    Temp. C
                                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                        <path d="M5 6l3-3 3 3M11 10l-3 3-3-3" />
                                    </svg>
                                </button>
                            </th>
                            <th>Temp. F</th>
                            <th>Humidity</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (PagedForecasts.Count == 0)
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="weather-grid-empty">No matching forecasts</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var forecast in PagedForecasts)
                            {
                                <tr @key="forecast.Date">
                                    <td class="cell-mono">@forecast.Date.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="cell-customer">
                                            <span class="cell-avatar @forecast.AvatarClass">@forecast.Code</span>
                                            <span>
                                                <span class="cell-strong">@forecast.Location</span>
                                                <span class="weather-station-meta">@forecast.Station</span>
                                            </span>
                                        </div>
                                    </td>
                                    <td><span class="role-chip @forecast.SummaryClass">@forecast.Summary</span></td>
                                    <td class="cell-strong">@forecast.TemperatureC C</td>
                                    <td>@forecast.TemperatureF F</td>
                                    <td>@forecast.Humidity%</td>
                                    <td><span class="status @forecast.StatusClass">@forecast.Status</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="weather-grid-footer">
            <span>Showing @StartEntry to @EndEntry of @FilteredCount entries</span>
            <div class="weather-pagination" aria-label="Weather pagination">
                <button type="button" class="weather-page-btn" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                @for (var page = 1; page <= TotalPages; page++)
                {
                    var pageNumber = page;
                    <button type="button" class="weather-page-btn @(pageNumber == currentPage ? "active" : null)" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                }
                <button type="button" class="weather-page-btn" disabled="@(currentPage == TotalPages)" @onclick="NextPage">Next</button>
            </div>
        </div>
    }
</div>

@code {
    private WeatherForecast[]? forecasts;
    private string searchTerm = string.Empty;
    private string sortColumn = "Date";
    private bool sortDescending;
    private int pageSize = 25;
    private int currentPage = 1;

    protected override async Task OnInitializedAsync() => await LoadForecastsAsync();

    private async Task RefreshForecastsAsync()
    {
        forecasts = null;
        currentPage = 1;
        StateHasChanged();
        await LoadForecastsAsync();
    }

    private async Task LoadForecastsAsync()
    {
        await Task.Delay(500);
        forecasts = GenerateForecasts();
    }

    private static WeatherForecast[] GenerateForecasts()
    {
        var startDate = DateOnly.FromDateTime(DateTime.Now);
        var summaries = new[] { "Freezing", "Bracing", "Chilly", "Cool", "Mild", "Warm", "Balmy", "Hot", "Sweltering", "Scorching" };
        var locations = new[]
        {
            new LocationInfo("Riga", "RIX", "Station LV-01", "avatar-teal"),
            new LocationInfo("London", "LDN", "Station UK-14", "avatar-blue"),
            new LocationInfo("New York", "NYC", "Station US-21", "avatar-green"),
            new LocationInfo("Sao Paulo", "SAO", "Station BR-08", "avatar-yellow"),
            new LocationInfo("Berlin", "BER", "Station DE-04", "avatar-purple")
        };

        return Enumerable.Range(1, 25).Select(index =>
        {
            var location = locations[(index - 1) % locations.Length];
            var temperature = Random.Shared.Next(-8, 42);
            var summary = summaries[Random.Shared.Next(summaries.Length)];

            return new WeatherForecast
            {
                Date = startDate.AddDays(index),
                Location = location.Name,
                Code = location.Code,
                Station = location.Station,
                AvatarClass = location.AvatarClass,
                TemperatureC = temperature,
                Humidity = Random.Shared.Next(36, 92),
                Summary = summary
            };
        }).ToArray();
    }

    private IReadOnlyList<WeatherForecast> FilteredForecasts
    {
        get
        {
            if (forecasts is null)
            {
                return [];
            }

            IEnumerable<WeatherForecast> query = forecasts;

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                query = query.Where(f =>
                    f.Date.ToString("MMM dd, yyyy").Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    f.Location.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    f.Station.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    f.Summary.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    f.Status.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
            }

            query = (sortColumn, sortDescending) switch
            {
                ("Location", false) => query.OrderBy(f => f.Location),
                ("Location", true) => query.OrderByDescending(f => f.Location),
                ("Summary", false) => query.OrderBy(f => f.Summary),
                ("Summary", true) => query.OrderByDescending(f => f.Summary),
                ("TemperatureC", false) => query.OrderBy(f => f.TemperatureC),
                ("TemperatureC", true) => query.OrderByDescending(f => f.TemperatureC),
                ("Date", true) => query.OrderByDescending(f => f.Date),
                _ => query.OrderBy(f => f.Date)
            };

            return query.ToArray();
        }
    }

    private IReadOnlyList<WeatherForecast> PagedForecasts => FilteredForecasts
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToArray();

    private int FilteredCount => FilteredForecasts.Count;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCount / (double)pageSize));
    private int StartEntry => FilteredCount == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndEntry => Math.Min(currentPage * pageSize, FilteredCount);

    private string CsvDataUri => forecasts is null
        ? "#"
        : $"data:text/csv;charset=utf-8,{Uri.EscapeDataString(BuildCsv(FilteredForecasts))}";

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var selectedPageSize))
        {
            pageSize = selectedPageSize;
            currentPage = 1;
        }
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }

        currentPage = 1;
    }

    private string SortClass(string column) => sortColumn == column
        ? (sortDescending ? "active desc" : "active asc")
        : string.Empty;

    private void PreviousPage() => GoToPage(currentPage - 1);

    private void NextPage() => GoToPage(currentPage + 1);

    private void GoToPage(int page)
    {
        currentPage = Math.Clamp(page, 1, TotalPages);
    }

    private static string BuildCsv(IReadOnlyList<WeatherForecast> items)
    {
        var lines = new List<string>
        {
            "Date,Location,Summary,TemperatureC,TemperatureF,Humidity,Status"
        };

        lines.AddRange(items.Select(f => string.Join(",",
            f.Date.ToString("yyyy-MM-dd"),
            EscapeCsv(f.Location),
            EscapeCsv(f.Summary),
            f.TemperatureC,
            f.TemperatureF,
            f.Humidity,
            EscapeCsv(f.Status))));

        return string.Join(Environment.NewLine, lines);
    }

    private static string EscapeCsv(string value) => $"\"{value.Replace("\"", "\"\"")}\"";

    private sealed record LocationInfo(string Name, string Code, string Station, string AvatarClass);

    private sealed class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public string Location { get; set; } = string.Empty;
        public string Code { get; set; } = string.Empty;
        public string Station { get; set; } = string.Empty;
        public string AvatarClass { get; set; } = "avatar-teal";
        public int TemperatureC { get; set; }
        public int Humidity { get; set; }
        public string Summary { get; set; } = string.Empty;
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);

        public string Status => TemperatureC switch
        {
            <= 0 => "Cold",
            >= 32 => "Hot",
            _ => "Stable"
        };

        public string StatusClass => TemperatureC switch
        {
            <= 0 => "status-blue",
            >= 32 => "status-yellow",
            _ => "status-green"
        };

        public string SummaryClass => Summary switch
        {
            "Freezing" or "Bracing" or "Chilly" => "role-blue",
            "Hot" or "Sweltering" or "Scorching" => "role-red",
            "Balmy" or "Warm" => "role-green",
            _ => "role-purple"
        };
    }
}
